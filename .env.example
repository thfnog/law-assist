# --- LLM & AI ---
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL_NAME=llama3-70b-8192

# --- DATABASE (Supabase Postgres) ---
# Format: postgresql://postgres:[password]@db.[id].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:your_db_password@db.your_id.supabase.co:5432/postgres

# --- SUPABASE AUTH & API ---
SUPABASE_URL=https://your_project_id.supabase.co
SUPABASE_KEY=your_anon_public_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_JWT_SECRET=your_jwt_secret_for_token_verification

# --- EVOLUTION API (WhatsApp) ---
EVOLUTION_API_URL=https://your_evolution_api_url
EVOLUTION_API_KEY=your_api_key
EVOLUTION_INSTANCE_NAME=law-assist-main

# --- TRELLO ---
TRELLO_API_KEY=your_trello_key
TRELLO_TOKEN=your_trello_token
TRELLO_BOARD_ID=your_board_id
TRELLO_LIST_ID_CLIENTS=your_list_id

# --- GOOGLE DRIVE & DOCS ---
GOOGLE_SERVICE_ACCOUNT_FILE=service-account.json
GOOGLE_DRIVE_PARENT_FOLDER_ID=your_folder_id
GOOGLE_DOCS_CONTRACT_TEMPLATE_ID=your_template_id

# --- APP CONFIG ---
DEBUG=True
PORT=8000
